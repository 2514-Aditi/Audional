# Pronunciation Assessment Backend Configuration

# Engine mode: 'whisperx' (requires CUDA + WhisperX library) or 'mock' (runs CPU-only with high-fidelity simulated timing)
ENGINE_MODE=mock

# Whisper model to use (tiny, base, small, medium, large-v2)
WHISPER_MODEL=base

# Hugging Face token (needed for WhisperX diarization models, optional for transcription/alignment)
HF_TOKEN=

# Directory to save processed uploads
UPLOAD_DIR=uploads

# Port and Host configurations
HOST=127.0.0.1
PORT=8000
